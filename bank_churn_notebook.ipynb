   "source": [
    "### 4.4 · Confusion Matrices"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "91dff63f",
   "metadata": {
    "tags": []
   },
   "outputs": [],
   "source": [
    "fig6, axes = plt.subplots(1, 3, figsize=(16, 5))\n",
    "fig6.patch.set_facecolor(BG)\n",
    "fig6.suptitle(\"Confusion Matrices\", fontsize=16, fontweight=\"bold\")\n",
    "\n",
    "for ax, (name, res), color in zip(axes, results.items(), COLORS):\n",
    "    cm     = confusion_matrix(y_test, res[\"y_pred\"])\n",
    "    cm_pct = cm / cm.sum(axis=1, keepdims=True) * 100\n",
    "    labels = np.array([[f\"{v}\\n({p:.1f}%)\" for v, p in zip(rv, rp)]\n",
    "                       for rv, rp in zip(cm, cm_pct)])\n",
    "    sns.heatmap(cm, annot=labels, fmt=\"\", ax=ax,\n",
    "                cmap=sns.light_palette(color, as_cmap=True),\n",
    "                linewidths=2, linecolor=\"white\", cbar=False,\n",
    "                xticklabels=[\"Stayed\",\"Churned\"], yticklabels=[\"Stayed\",\"Churned\"],\n",
    "                annot_kws={\"size\": 12, \"weight\": \"bold\"})\n",
    "    ax.set_title(name); ax.set_xlabel(\"Predicted\"); ax.set_ylabel(\"Actual\")\n",
    "\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
